# ============================================================================
# Yoga Sculpt — Espace client (app.yoga-sculpt.fr)
# Modèle de configuration. Copier en `.env.local` et remplir les vraies valeurs.
#
#   cp .env.example .env.local
#
# ⚠️ `.env.local` est gitignored : il contient les VRAIS secrets et ne doit
#    JAMAIS être commité. Ce fichier-ci (.env.example) ne contient QUE des
#    placeholders et EST commité (documentation publique de la config).
# ============================================================================

# ---- App ----
NEXT_PUBLIC_APP_URL=https://app.yoga-sculpt.fr
NEXT_PUBLIC_SITE_URL=https://yoga-sculpt.fr

# ---- Supabase ----
# Management API (création/admin du projet Supabase Cloud). Secret serveur.
SUPABASE_MANAGEMENT_TOKEN=
SUPABASE_ORG_ID=

# Clés du projet Supabase Cloud dédié.
# - NEXT_PUBLIC_* sont exposées au navigateur (anon key = OK, protégée par RLS).
# - SERVICE_ROLE_KEY est un secret serveur (bypass RLS) : ne JAMAIS l'exposer
#   côté client, ne JAMAIS la committer. En prod : `wrangler secret put`.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_DB_PASSWORD=
SUPABASE_PROJECT_REF=

# ---- OAuth providers (à configurer dans le dashboard Supabase Auth) ----
# Pour mémoire : ce qui compte, c'est de coller ces valeurs dans Supabase
# (c'est Supabase qui gère l'échange OAuth, pas l'app). Voir SETUP.md §3.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_TENANT_ID=

# ---- Cal.com ----
# Réservation publique d'une séance depuis l'onboarding.
CALCOM_USERNAME=
CALCOM_EVENT_SLUG=
# Clé API Cal.com (lecture/écriture via l'API REST Cal). Secret serveur.
CALCOM_API_KEY=
# Secret de SIGNATURE des webhooks Cal.com. ⚠️ DIFFÉRENT de CALCOM_API_KEY :
# c'est une chaîne que TU génères et que tu colles à la fois ici ET dans
# Cal.com → Settings → Webhooks (champ "Secret"). Sert à vérifier le HMAC
# du header X-Cal-Signature-256 sur /api/webhooks/cal. Voir WEBHOOKS.md.
# En prod : `wrangler secret put CALCOM_WEBHOOK_SECRET`.
CALCOM_WEBHOOK_SECRET=

# ---- Google Calendar (service account, lib edge src/lib/google-calendar.ts) ----
# JSON COMPLET de la clé de service account Google (string sur une ligne).
# On en extrait `client_email` + `private_key` (PEM PKCS#8). Secret serveur.
# En prod : `wrangler secret put GOOGLE_CALENDAR_SA_KEY`.
GOOGLE_CALENDAR_SA_KEY=
# Id du calendrier cible (souvent une adresse style ...@group.calendar.google.com).
GOOGLE_CALENDAR_ID=

# ---- Stripe (PHASE 2 — carnet de tickets / crédits de séances) ----
# Clé secrète serveur (sk_live_... / sk_test_...). En prod : `wrangler secret put`.
STRIPE_SECRET_KEY=
# Clé publishable (pk_...) — exposable côté client si besoin (non utilisée
# côté serveur pour l'instant ; conservée pour un futur Stripe.js).
STRIPE_PUBLISHABLE_KEY=
# Secret de SIGNATURE des webhooks Stripe (whsec_...). ⚠️ DIFFÉRENT de la clé
# secrète : Stripe le fournit à la création de l'endpoint webhook. Sert à
# vérifier le HMAC du header Stripe-Signature sur /api/webhooks/stripe.
# En prod : `wrangler secret put STRIPE_WEBHOOK_SECRET`.
STRIPE_WEBHOOK_SECRET=
# Price IDs Stripe (price_...) des formules d'achat. Créés dans le compte Stripe
# d'Alice par le team-lead (l'app ne crée PAS les produits, elle les lit ici).
#   - COLLECTIF   : ticket unitaire « cours collectif »   (1 séance)
#   - PARTICULIER : ticket unitaire « cours particulier »  (1 séance)
#   - CARTE10     : carte 10 séances (collectif)           (10 séances)
STRIPE_PRICE_COLLECTIF=
STRIPE_PRICE_PARTICULIER=
STRIPE_PRICE_CARTE10=
